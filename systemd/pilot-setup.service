[Unit]
Description=PiLot Initial Setup Wizard
Documentation=https://github.com/rtck/pilot
After=network.target
ConditionPathExists=!/var/lib/pilot/.setup-complete

[Service]
Type=simple
User=pilot
Environment=PYTHONPATH=/opt/pilot/src
ExecStart=/opt/pilot/venv/bin/uvicorn pilot_setup.main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5
MemoryMax=100M
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pilot-setup

[Install]
WantedBy=multi-user.target
